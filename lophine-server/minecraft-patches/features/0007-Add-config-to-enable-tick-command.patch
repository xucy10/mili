+    public static volatile long TIME_BETWEEN_TICKS = (long) (1_000_000_000L / TICK_RATE); // ns // Luminol - Add tick command support // Lophine - volatile for cross-region visibility
     // Folia start - watchdog
     public static final FoliaWatchdogThread WATCHDOG_THREAD = new FoliaWatchdogThread();
     static {
@@ -448,8 +448,31 @@ public final class TickRegionScheduler {
             final long cpuStart = MEASURE_CPU_TIME ? THREAD_MX_BEAN.getCurrentThreadCpuTime() : 0L;
             final long tickStart = System.nanoTime();
 
-            // use max(), don't assume that tickStart >= scheduledStart
-            final long tickCount = Math.max(1L, this.tickSchedule.getPeriodsAhead(TIME_BETWEEN_TICKS, tickStart));
+            // Luminol start - Add a config to enable tick command
+            final long tickCount;
+            if (fun.bm.lophine.config.modules.experiment.CommandConfig.tick) {
+                if (MinecraftServer.tickRateManager.isSprinting() && MinecraftServer.tickRateManager.checkShouldSprintThisTick()) {
+                    // Lophine start - atomic tick rate update: update TIME_BETWEEN_TICKS first then TICK_RATE
+                    // to avoid a reader seeing new TICK_RATE but old TIME_BETWEEN_TICKS
+                    final long newInterval = (long) (1_000_000_000L / net.minecraft.server.commands.TickCommand.MAX_TICKRATE);
+                    TIME_BETWEEN_TICKS = newInterval;
+                    TICK_RATE = net.minecraft.server.commands.TickCommand.MAX_TICKRATE;
+                    // Lophine end - atomic tick rate update
+                    tickCount = 1;
+                } else {
+                    // Lophine start - atomic tick rate update
+                    final float newRate = MinecraftServer.tickRateManager.tickrate();
+                    final long newInterval = (long) (1_000_000_000L / newRate);
+                    TIME_BETWEEN_TICKS = newInterval;
+                    TICK_RATE = newRate;
+                    // Lophine end - atomic tick rate update
+                    tickCount = Math.max(1L, this.tickSchedule.getPeriodsAhead(TIME_BETWEEN_TICKS, tickStart));
+                }
+            } else {
+                // use max(), don't assume that tickStart >= scheduledStart
+                tickCount = Math.max(1L, this.tickSchedule.getPeriodsAhead(TIME_BETWEEN_TICKS, tickStart));
+            }
+            // Luminol end - Add tick command support
 
             if (!this.tryMarkTicking()) {
                 if (!this.cancelled.get()) {
@@ -498,6 +513,15 @@ public final class TickRegionScheduler {
             try {
                 // next start isn't updated until the end of this tick
                 this.tickRegion(tickCount, tickStart, scheduledEnd);
+                // Luminol start - Add a config to enable tick command
+                if (fun.bm.lophine.config.modules.experiment.CommandConfig.tick) {
+                    try {
+                        MinecraftServer.tickRateManager.endTickWork();
+                    } catch (final Throwable t) {
+                        // Lophine - swallow to avoid killing the region scheduler thread
+                    }
+                }
+                // Luminol end - Add a config to enable tick command
             } catch (final Throwable thr) {
                 this.scheduler.regionFailed(this, false, thr);
                 // regionFailed will schedule a shutdown, so we should avoid letting this region tick further
