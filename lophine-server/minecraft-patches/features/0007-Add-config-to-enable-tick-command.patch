+    // Luminol start - Add tick command support
+    // Lophine start - use AtomicLong for thread safety across region threads
+    private final java.util.concurrent.atomic.AtomicLong _remainingSprintTicks = new java.util.concurrent.atomic.AtomicLong(0L);
+
+    // Delegate: keep the parent field in sync for reads that access it directly
+    private void syncRemainingSprintTicks() {
+        long val = this._remainingSprintTicks.get();
+        this.remainingSprintTicks = val;
+    }
+
+    public void reduceSprintTicks() {
+        this._remainingSprintTicks.decrementAndGet();
+        this.syncRemainingSprintTicks();
+    }
+
+    public void setSprintTicks(long ticks) {
+        this._remainingSprintTicks.set(ticks);
+        this.syncRemainingSprintTicks();
+    }
+    // Lophine end - use AtomicLong for thread safety
+    // Luminol end - Add tick command support
+
     public void endTickWork() {
         this.sprintTimeSpend = this.sprintTimeSpend + (System.nanoTime() - this.sprintTickStartTime);
     }
