From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Lophine <lophine@dev.null>
Date: Fri, 12 Jun 2026 00:00:00 +0800
Subject: [PATCH] Entity tracking broadcast performance optimization

Throttles entity tracking broadcasts to reduce network latency when many
entities are near players. Uses hash-based round-robin budget distribution
to spread updates evenly across ticks and TPS-aware throttling during lag.

diff --git a/net/minecraft/server/level/ChunkMap.java b/net/minecraft/server/level/ChunkMap.java
index 2b78040daeb3b09c08494cbc1d4a9d36080895f9..51cd683a9e0f1c2d3b4a5968776a5b4c3d2e1f0a 100644
--- a/net/minecraft/server/level/ChunkMap.java
+++ b/net/minecraft/server/level/ChunkMap.java
@@ -1305,6 +1305,7 @@
     protected void tick(BooleanSupplier hasTimeLeft) {
         ProfilerFiller profilerFiller = Profiler.get();
         profilerFiller.push("chunkMap");
+        fun.bm.mili.utils.EntityTrackingThrottle.onTickStart(); // Lophine - Entity tracking perf
         // Folia start - region threading - chunk sending
         if (!this.level.isIteratingTickingRegions()) {
         this.distanceManager.purgeStaleTickets();
@@ -1371,5 +1372,9 @@
         // Paper start - optimise entity tracker
         for (TrackedEntity trackedEntity : this.entityMap.values()) {
-            trackedEntity.broadcastChanges();
+            // Lophine start - Entity tracking perf
+            if (fun.bm.mili.utils.EntityTrackingThrottle.shouldBroadcast(trackedEntity.entity)) {
+                trackedEntity.broadcastChanges();
+            }
+            // Lophine end
         }
         // Paper end - optimise entity tracker
