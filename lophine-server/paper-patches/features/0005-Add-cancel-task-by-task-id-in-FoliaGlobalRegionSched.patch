From: Helvetica Volubi <suisuroru@blue-millennium.fun>
Date: Sat, 22 Nov 2025 01:43:26 +0800
Subject: [PATCH] Add cancel task by task id in FoliaGlobalRegionScheduler


diff --git a/src/main/java/io/papermc/paper/threadedregions/scheduler/FoliaGlobalRegionScheduler.java b/src/main/java/io/papermc/paper/threadedregions/scheduler/FoliaGlobalRegionScheduler.java
index 14ffbcb66006878eacf310547dad53718f8308eb..6c108bc7d93196803daeef4751d06cafa6eeec1a 100644
--- a/src/main/java/io/papermc/paper/threadedregions/scheduler/FoliaGlobalRegionScheduler.java
+++ b/src/main/java/io/papermc/paper/threadedregions/scheduler/FoliaGlobalRegionScheduler.java
@@ -16,6 +16,8 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
     private long tickCount = 0L;
     private final Object stateLock = new Object();
     private final Long2ObjectOpenHashMap<List<GlobalScheduledTask>> tasksByDeadline = new Long2ObjectOpenHashMap<>();
+    private final java.util.concurrent.atomic.AtomicInteger lastTaskId = new java.util.concurrent.atomic.AtomicInteger(1); // Lophine - task uid
+    private final java.util.concurrent.ConcurrentHashMap<Integer, GlobalScheduledTask> taskIndex = new java.util.concurrent.ConcurrentHashMap<>(); // Lophine - task uid index
 
     public void tick() {
         final List<GlobalScheduledTask> run;
@@ -64,7 +66,7 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
             throw new IllegalPluginAccessException("Plugin attempted to register task while disabled");
         }
 
-        final GlobalScheduledTask ret = new GlobalScheduledTask(plugin, -1, task);
+        final GlobalScheduledTask ret = new GlobalScheduledTask(plugin, -1, task, this.getNextTaskId()); // Lophine - task uid
 
         this.scheduleInternal(ret, delayTicks);
 
@@ -91,7 +93,7 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
             throw new IllegalPluginAccessException("Plugin attempted to register task while disabled");
         }
 
-        final GlobalScheduledTask ret = new GlobalScheduledTask(plugin, periodTicks, task);
+        final GlobalScheduledTask ret = new GlobalScheduledTask(plugin, periodTicks, task, this.getNextTaskId()); // Lophine - task uid
 
         this.scheduleInternal(ret, initialDelayTicks);
 
@@ -133,7 +135,77 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
         }
     }
 
-    private final class GlobalScheduledTask implements ScheduledTask, Runnable {
+    // Lophine start - enhanced task uid system
+    /**
+     * Cancel a single task by its unique ID. O(1) via index lookup.
+     * @return true if the task was found and cancelled
+     */
+    public boolean cancelTask(final int taskId) {
+        GlobalScheduledTask task = this.taskIndex.get(taskId);
+        if (task != null) {
+            task.cancel();
+            this.taskIndex.remove(taskId);
+            return true;
+        }
+        return false;
+    }
+
+    /**
+     * Cancel all tasks belonging to a specific plugin. O(n) but scoped.
+     * @return number of tasks cancelled
+     */
+    public int cancelTasksByPlugin(final Plugin plugin) {
+        int count = 0;
+        synchronized (this.stateLock) {
+            for (final List<GlobalScheduledTask> tasks : this.tasksByDeadline.values()) {
+                for (final GlobalScheduledTask task : tasks) {
+                    if (task.plugin == plugin) {
+                        task.cancel();
+                        this.taskIndex.remove(task.taskId);
+                        count++;
+                    }
+                }
+            }
+        }
+        return count;
+    }
+
+    /** Retrieve a scheduled task by its unique ID. O(1). */
+    public GlobalScheduledTask getTask(final int taskId) {
+        return this.taskIndex.get(taskId);
+    }
+
+    /** Get the number of currently indexed tasks. */
+    public int getTaskCount() {
+        return this.taskIndex.size();
+    }
+
+    private int getNextTaskId() {
+        int id;
+        do {
+            id = this.lastTaskId.incrementAndGet();
+            if (id <= 0) {
+                this.lastTaskId.compareAndSet(id, 1);
+            }
+        } while (id <= 0);
+        // Periodic purge of finished/cancelled tasks to prevent taskIndex memory leak
+        // Size-based trigger avoids per-tick overhead; only runs when index grows large
+        if (this.taskIndex.size() > 128) {
+            this.purgeStaleTaskIndex();
+        }
+        return id;
+    }
+
+    private void purgeStaleTaskIndex() {
+        this.taskIndex.entrySet().removeIf(e -> {
+            int s = e.getValue().getStateVolatile();
+            return s == GlobalScheduledTask.STATE_CANCELLED
+                || s == GlobalScheduledTask.STATE_FINISHED;
+        });
+    }
+    // Lophine end - enhanced task uid system
+
+    public final class GlobalScheduledTask implements ScheduledTask, Runnable { // Lophine - private -> public
 
         private static final int STATE_IDLE                = 0;
         private static final int STATE_EXECUTING           = 1;
@@ -145,13 +191,15 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
         private final long repeatDelay; // in ticks
         private Consumer<ScheduledTask> run;
         private volatile int state;
+        private final int taskId; // Lophine - task uid
 
         private static final VarHandle STATE_HANDLE = ConcurrentUtil.getVarHandle(GlobalScheduledTask.class, "state", int.class);
 
-        private GlobalScheduledTask(final Plugin plugin, final long repeatDelay, final Consumer<ScheduledTask> run) {
+        private GlobalScheduledTask(final Plugin plugin, final long repeatDelay, final Consumer<ScheduledTask> run, int taskId) { // Lophine - task uid
             this.plugin = plugin;
             this.repeatDelay = repeatDelay;
             this.run = run;
+            this.taskId = taskId; // Lophine - task uid
         }
 
         private final int getStateVolatile() {
@@ -262,5 +310,11 @@ public class FoliaGlobalRegionScheduler implements GlobalRegionScheduler {
                 }
             }
         }
+
+        // Lophine start - task uid accessor
+        public int getTaskId() {
+            return this.taskId;
+        }
+        // Lophine end - task uid accessor
     }
 }
